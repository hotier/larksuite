# ===== 飞书开放平台应用 =====
# 飞书开放平台创建的应用 App ID
APP_ID=your_app_id

# 飞书应用 App Secret
APP_SECRET=your_app_secret

# OAuth 回调地址（需与飞书开放平台后台配置保持一致；部署时改为线上域名）
REDIRECT_URI=http://localhost:3000/api/auth/callback

# ===== 数据库 =====
# PostgreSQL 连接串（本地 Postgres 或 Neon Serverless 均可）
DATABASE_URL=postgres://user:password@localhost:5432/feishu_bitable

# ===== 定时任务鉴权（可选）=====
# 内部 cron / keepalive 接口的共享密钥；未设置时跳过校验
CRON_SECRET=your_cron_secret

# ===== 缓存（可选）=====
# 内存缓存默认 TTL（毫秒），默认 300000（5 分钟）
CACHE_TTL_MS=300000
